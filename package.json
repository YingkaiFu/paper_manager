{
  "name": "paper_manager",
  "version": "0.3.0",
  "private": true,
  "main": "./main.js",
  "author": {
    "name": "Yingkai Fu",
    "email": "Yingkai.Fu@outlook.com"
  },
  "icon": "./assets/icons/logo.ico",
  "description": "A paper manager for researchers",
  "homepage": ".",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "antd": "^5.24.6",
    "axios": "^1.9.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron-is-dev": "^2.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "nedb": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wait-on": "^8.0.3",
    "xml2js": "^0.6.2"
  },
  "scripts": {
    "dev": "concurrently -k \"cross-env BROWSER=none vite\" \"wait-on tcp:5173 && electron .\"",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node -e \"console.log('No test runner configured; see docs/development.md')\"",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "electron-start": "electron-forge start",
    "electron-package": "electron-forge package",
    "electron-make": "electron-forge make",
    "builder": "electron-builder"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^27.3.11",
    "electron-builder": "^24.13.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "paper_manager",
    "productName": "paper_manager",
    "copyright": "GPL 3.0",
    "directories": {
      "buildResources": "installer",
      "output": "dist"
    },
    "nsis": {
      "oneClick": false,
      "language": "2052",
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "icon": "./assets/icons/logo.ico",
      "target": "nsis"
    },
    "files": [
      "build/**/*",
      "./main.js",
      "./preload.js",
      "./libraryScan.js"
    ],
    "extends": null
  }
}
